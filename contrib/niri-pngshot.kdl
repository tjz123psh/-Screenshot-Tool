// pngshot — Niri integration example
//
// The installer tries to add the keybinds automatically to the active,
// user-owned dms/keybinds.kdl. If that is not possible (for example because
// a key is already occupied), merge the relevant lines into that file and
// reload Niri. This file is an example; it is never sourced automatically.

// ---------------------------------------------------------------------------
// 1) Deskpin window rule
//
// The pin window sets title "pngshot-pin". niri matches on title here so the
// pinned screenshot always opens floating (niri's equivalent of "always on
// top") without a border or focus ring.
//
// pngshot also calls `niri msg action move-window-to-floating` itself right
// after the window maps, so this rule is optional — but adding it removes the
// brief tiled flash and lets you fix a default size.

window-rule {
    match title="pngshot-pin"

    open-floating true
    // Keep the pin visually clean:
    focus-ring {
        off
    }
    border {
        off
    }
    // Optional: give every pin a sane starting size (it's still zoomable).
    // default-column-width { fixed 800; }
    // default-window-height { fixed 600; }
}

// The Stage-1 selection overlay is a layer-shell surface (namespace
// "pngshot-overlay"), not a normal window, so it needs no window-rule.

// ---------------------------------------------------------------------------
// 2) Keybinds
//
// Put these inside your existing `binds { ... }` block in
// ~/.config/niri/dms/keybinds.kdl.

binds {
    // Super+Print: interactive region screenshot.
    Mod+Print hotkey-overlay-title="pngshot 框选" {
        spawn-sh "$HOME/.local/bin/pngshot region";
    }

    // Super+Shift+Print: region screenshot straight into long-shot mode.
    Mod+Shift+Print hotkey-overlay-title="pngshot 长截图" {
        spawn-sh "$HOME/.local/bin/pngshot long";
    }

    // Super+Ctrl+Print: pin the current clipboard image.
    Mod+Ctrl+Print hotkey-overlay-title="pngshot 钉图" {
        spawn-sh "$HOME/.local/bin/pngshot pin-last";
    }

}
