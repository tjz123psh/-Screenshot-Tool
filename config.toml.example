# pngshot 配置示例
# 复制到 ~/.config/pngshot/config.toml 后按需修改。
# 不存在此文件时，全部使用下面的默认值。

[llm]
# provider: "opencode"（默认，走本机 opencode CLI 免费模型）或 "openai"（走 OPENAI_API_KEY）
provider    = "opencode"
# opencode 免费模型无需登录；也可换成 opencode models 里的其它模型
model       = "opencode/deepseek-v4-flash-free"
# 翻译目标语言（源语言自动识别）
target_lang = "简体中文"
# 单次翻译超时（秒）。若本机服务未启动，会自动回退 opencode CLI
timeout_s   = 30
# 若此端口已有 opencode serve，优先复用其 HTTP API，避免每次翻译冷启动
serve_port  = 47823

[ocr]
# 识别引擎："tesseract"（默认，本地、快、离线）或 "vision"（走 opencode 视觉
# 模型，小字/低对比/中英混排明显更强，但需要 opencode + 网络、较慢 2-3s）。
# vision 失败会自动回退 tesseract，不会让你什么都拿不到。
engine = "tesseract"
# tesseract 语言包，用 + 组合。已装：chi_sim eng osd
langs = "chi_sim+eng"
# tesseract 识别前预处理：放大 + 灰度 + 深色主题自动反色。实测能把小字乱码行
# 纠正为正确文字，几乎零成本。
preprocess = true
# 预处理放大倍数。屏幕截图约 96 DPI，tesseract 偏好 ~300 DPI，放大 3x 正合适。
upscale = 3.0
# engine = "vision" 时使用的模型，任意支持视觉的 opencode 模型均可。
vision_model = "google/gemini-flash-latest"
# vision 调用超时（秒），超时后回退 tesseract。
vision_timeout_s = 30

[longshot]
# 采帧间隔（毫秒）。0 = 全速背靠背抓帧（推荐）；调大可省 CPU，但快速滚动时可能缺少桥接帧
poll_ms      = 0
# 一帧至少要贡献这么多新行才追加，过滤原地微抖
min_shift_px = 4
# 重叠区行签名差异阈值；超过时会继续采样并尝试从最近历史帧恢复（越低越严格）
max_diff     = 9.0
